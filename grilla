int cant_fil = 15;
int canr_col = 9;
boolean[][]FueCliqueado;
void setup() {
  size(800, 600);
  FueCliqueado = new boolean [15][9];
}
void draw() {
  float ancho = width/9;
  float alto = height/15;
  for (int i = 0; i<9; i++) {
    for (int j = 0; j<15; j++) {
      float x = i*ancho;
      float y = j*alto;
      rect( x, y, ancho, alto);
    }
  }
}
